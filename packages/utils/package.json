{
  "name": "@hollis-studio/utils",
  "version": "0.1.0-alpha.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hollis-Studio/hollis-shared.git",
    "directory": "packages/utils"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./csrf": {
      "types": "./dist/csrf.d.ts",
      "import": "./dist/csrf.js",
      "default": "./dist/csrf.js"
    },
    "./dateKey": {
      "types": "./dist/dateKey.d.ts",
      "import": "./dist/dateKey.js",
      "default": "./dist/dateKey.js"
    },
    "./formatCurrency": {
      "types": "./dist/formatCurrency.d.ts",
      "import": "./dist/formatCurrency.js",
      "default": "./dist/formatCurrency.js"
    },
    "./unitConversions": {
      "types": "./dist/unitConversions.d.ts",
      "import": "./dist/unitConversions.js",
      "default": "./dist/unitConversions.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@hollis-studio/contracts": "0.2.0-alpha.8"
  },
  "devDependencies": {
    "typescript": "5.9.2"
  }
}
